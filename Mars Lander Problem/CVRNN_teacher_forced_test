#This script implements the testing code for the CVRNN
import torch
import torch.nn as nn
import glob
import os
import pandas as pd
import matplotlib.pyplot as plt


device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
checkpoint = torch.load("stepwise_cvae.pth", map_location=device)

state_dim = checkpoint["state_dim"]  # 9
control_dim = checkpoint["control_dim"]  # 3
latent_dim = checkpoint["latent_dim"]  # 32
hidden_dim = checkpoint["hidden_dim"]  # 128
T = checkpoint["T"]  # 100

state_mean = checkpoint["state_mean"].to(device)
state_std = checkpoint["state_std"].to(device)
ctrl_mean = checkpoint["ctrl_mean"].to(device)
ctrl_std = checkpoint["ctrl_std"].to(device)

class Decoder(nn.Module):
    def __init__(self, latent_dim, state_dim, control_dim, hidden_dim):
        super().__init__()
        in_dim = latent_dim + state_dim + control_dim
        self.net = nn.Sequential(
            nn.Linear(in_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.GELU(),
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.GELU(),
            nn.Linear(hidden_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.GELU(),
            nn.Linear(hidden_dim, state_dim),
        )

    def forward(self, z, s_t, u_t):
        return self.net(torch.cat([z, s_t, u_t], dim=1))


decoder = Decoder(latent_dim, state_dim, control_dim, hidden_dim).to(device)
decoder.load_state_dict(checkpoint["decoder_state_dict"])
decoder.eval()

def load_test_traj(folder_path, file_pattern):
    csv_files = sorted(glob.glob(os.path.join(folder_path, file_pattern)))
    # Pick a sample from the test set (e.g., index 30)
    df = pd.read_csv(csv_files[301], header=0).astype(float)
    df = df.iloc[:, 1:]
    return torch.tensor(df.values, dtype=torch.float32).T.unsqueeze(0)  # [1, 12, T]


A_path = "C:/Users/nubapat/OneDrive - Worcester Polytechnic Institute (wpi.edu)/Documents/Desktop/Journal_2025_work/data_process_real_noise"
full_data = load_test_traj(A_path, "*_*_process_noise_real.csv")  # [1, 12, T]

true_states = full_data[:, :state_dim, :]  # [1, 9, T]
true_controls = full_data[:, state_dim:, :]  # [1, 3, T]

num_samples = 5
plt.figure(figsize=(10, 6))
plt.plot(true_states[0, 1, :].numpy(), true_states[0, 2, :].numpy(),
         color='black', linewidth=3, label="Ground Truth")

for i in range(num_samples):
    with torch.no_grad():
        # 1. Sample z
        z = torch.randn(1, latent_dim).to(device)

        # 2. Get initial state and normalize
        s_t = (true_states[:, :, 0].to(device) - state_mean.squeeze(-1)) / state_std.squeeze(-1)
        u_seq = (true_controls.to(device) - ctrl_mean) / ctrl_std

        generated_states = [true_states[:, :, 0]]  # Start with unnormalized s0

        # 3. Step through time
        for t in range(T - 1):
            u_t = u_seq[:, :, t]

            # Predict next state (normalized)
            s_t = decoder(z, s_t, u_t)

            # Denormalize for plotting
            s_t_unnorm = s_t * state_std.squeeze(-1) + state_mean.squeeze(-1)
            generated_states.append(s_t_unnorm.cpu())

        # Combine into [9, T]
        pred_traj = torch.cat(generated_states, dim=0).T  # [9, T]

        plt.plot(pred_traj[1, :], pred_traj[2, :],
                 linestyle='--', alpha=0.7, label=f"Sample {i + 1}")

plt.title("Stepwise Autoregressive Rollout")
plt.xlabel("X Position")
plt.ylabel("Y Position")
plt.legend()
plt.grid(True)
plt.show()
