def stepwise_recon_loss(decoder, z, s_traj, u_traj):
    loss = 0.0
    for t in range(T - 1):
        s_t      = s_traj[:, :, t]          # [B, 9]
        u_t      = u_traj[:, :, t]          # [B, 3]
        s_t1_gt  = s_traj[:, :, t + 1]     # [B, 9]
        s_t1_hat = decoder(z, s_t, u_t)    # [B, 9]
        loss     = loss + F.mse_loss(s_t1_hat, s_t1_gt, reduction='sum')
    return loss 

epochs     = 100
batch_size = 32

A_states_dev   = A_states_n.to(device)    # [N_A, 9, T]
A_controls_dev = A_controls_n.to(device)
B_states_dev   = B_states_n.to(device)
B_controls_dev = B_controls_n.to(device)

loss_history = []
mi_history   = []

for epoch in range(epochs):
    max_len    = max(len(A_states_dev), len(B_states_dev))
    num_batches= max_len // batch_size
    def tile(x, target):
        reps = (target // len(x)) + 1
        return x.repeat(reps, *([1] * (x.dim() - 1)))[:target]

    sA = tile(A_states_dev,   max_len)
    uA = tile(A_controls_dev, max_len)
    sB = tile(B_states_dev,   max_len)
    uB = tile(B_controls_dev, max_len)

    # Shuffle
    sA = sA[torch.randperm(max_len)]
    uA = uA[torch.randperm(max_len)]
    sB = sB[torch.randperm(max_len)]
    uB = uB[torch.randperm(max_len)]

    tot_loss = tot_mi = tot_kl1 = tot_kl2 = 0.0

    for b in range(num_batches):
        sl = slice(b * batch_size, (b + 1) * batch_size)
        sA_b = sA[sl];  uA_b = uA[sl]    # [B, 9, T] / [B, 3, T]
        sB_b = sB[sl];  uB_b = uB[sl]

        mu1_A_enc, logvar1_A_enc = encoder1(sA_b, uA_b)
        z1_A_batch = reparam(mu1_A_enc, logvar1_A_enc)

        mu1_B_enc, logvar1_B_enc = encoder1(sB_b, uB_b)
        z1_B_batch = reparam(mu1_B_enc, logvar1_B_enc)
        mu2_enc, logvar2_enc = encoder2(
            torch.cat([sA_b, sB_b], dim=0),
            torch.cat([uA_b, uB_b], dim=0)
        )
        z_shared   = reparam(mu2_enc, logvar2_enc)
        z2_A_batch = z_shared[:batch_size]
        z2_B_batch = z_shared[batch_size:]

    
        zA_full = torch.cat([z1_A_batch, z2_A_batch], dim=1)  # [B, 64]
        zB_full = torch.cat([z1_B_batch, z2_B_batch], dim=1)

        rec_loss = (stepwise_recon_loss(decoderA, zA_full, sA_b, uA_b) +
                    stepwise_recon_loss(decoderB, zB_full, sB_b, uB_b))

        
        kl1_A = kl_diag(mu1_A_enc, logvar1_A_enc, mu1_A, logvar1_A).sum()
        kl1_B = kl_diag(mu1_B_enc, logvar1_B_enc, mu1_B, logvar1_B).sum()
        kl1   = kl1_A + kl1_B
        kl2   = kl_diag(mu2_enc, logvar2_enc,
                         torch.zeros_like(mu2_enc),
                         torch.zeros_like(logvar2_enc)).sum()

       
        mi_z1 = mi_loss_z1(z1_A_batch, z1_B_batch)

    
        if epoch >= mi_warmup_epochs:
            loss = rec_loss + lambda1 * kl1 + lambda2 * kl2 + beta * mi_z1
        else:
            loss = rec_loss + lambda1 * kl1 + lambda2 * kl2

        optimizer.zero_grad()
        loss.backward()
        optimizer.step()

        tot_loss += loss.item()
        tot_mi   += mi_z1.item()
        tot_kl1  += kl1.item()
        tot_kl2  += kl2.item()

    loss_history.append(tot_loss / max_len)
    mi_history.append(tot_mi / num_batches)

    print(f"Epoch {epoch+1}/{epochs} | "
          f"Loss: {tot_loss/max_len:.4f} | "
          f"KL1: {tot_kl1/max_len:.4f} | KL2: {tot_kl2/max_len:.4f} | "
          f"MI: {tot_mi/num_batches:.4f}")


plt.figure(figsize=(10, 4))
plt.subplot(1, 2, 1); plt.plot(loss_history); plt.title("Total Loss");  plt.grid(True)
plt.subplot(1, 2, 2); plt.plot(mi_history);   plt.title("MI(z1_A,z1_B)"); plt.grid(True)
