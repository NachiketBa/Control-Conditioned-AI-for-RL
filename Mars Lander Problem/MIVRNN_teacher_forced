mu1_A    = torch.zeros(z1_dim, device=device)
logvar1_A= torch.zeros(z1_dim, device=device)
mu1_B    = torch.ones(z1_dim,  device=device)
logvar1_B= torch.log(torch.ones(z1_dim, device=device) * 2.0)

