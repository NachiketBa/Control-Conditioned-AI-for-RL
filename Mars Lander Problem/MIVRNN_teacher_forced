def rollout(s0, u_seq, decoder, z,
            state_mean, state_std, ctrl_mean, ctrl_std):

    decoder.eval()
    with torch.no_grad():
        B = s0.shape[0]
        s_n = (s0.to(device) - state_mean.squeeze(-1).to(device)) \
               / state_std.squeeze(-1).to(device)
        u_n = (u_seq.to(device) - ctrl_mean.to(device)) / ctrl_std.to(device)

        traj = [s_n]
        s_t  = s_n
        for t in range(u_seq.shape[-1]):
            u_t = u_n[:, :, t]
            s_t = decoder(z, s_t, u_t)
            traj.append(s_t)

        traj = torch.stack(traj, dim=2)        # [B, 9, T]
        return traj * state_std.to(device) + state_mean.to(device)
