class TrajectoryDataset(Dataset):
    def __init__(self, states, controls, label):
        self.states   = states    # [N, 9, T]
        self.controls = controls  # [N, 3, T]
        self.label    = label

    def __len__(self):
        return self.states.size(0)

    def __getitem__(self, idx):
        return self.states[idx], self.controls[idx], self.label

dataset_A = TrajectoryDataset(A_states_n, A_controls_n, label=0)
dataset_B = TrajectoryDataset(B_states_n, B_controls_n, label=1)

# ---------------------------
# ---------------------------
class Encoder(nn.Module):
    def __init__(self, in_dim, z_dim, hidden_dim):
        super().__init__()
        self.step_proj = nn.Linear(state_dim + control_dim, in_dim)
        self.fc1      = nn.Linear(in_dim, hidden_dim)
        self.ln1      = nn.LayerNorm(hidden_dim)
        self.fc2      = nn.Linear(hidden_dim, hidden_dim)
        self.ln2      = nn.LayerNorm(hidden_dim)
        self.fc_mu    = nn.Linear(hidden_dim, z_dim)
        self.fc_logvar= nn.Linear(hidden_dim, z_dim)

    def forward(self, s, u):
        B, _, Tlen = s.shape
        su = torch.cat([s, u], dim=1).permute(0, 2, 1)        # [B, T, 12]
        su = su.reshape(B * Tlen, state_dim + control_dim)

        h  = self.step_proj(su)                                # [B*T, in_dim]
        h  = h.reshape(B, Tlen, -1).mean(dim=1)               
        h  = F.relu(self.ln1(self.fc1(h)))
        h  = F.relu(self.ln2(self.fc2(h)))
        return self.fc_mu(h), self.fc_logvar(h)


# --------------------------
# ---------------------------
class Decoder(nn.Module):
    def __init__(self, z_dim, hidden_dim):
        super().__init__()
        in_dim = z_dim + state_dim + control_dim

        # Original decoder body — unchanged
        self.fc1   = nn.Linear(in_dim, hidden_dim)
        self.ln1   = nn.LayerNorm(hidden_dim)
        self.fc2   = nn.Linear(hidden_dim, hidden_dim)
        self.ln2   = nn.LayerNorm(hidden_dim)
        self.fc_out= nn.Linear(hidden_dim, state_dim)   # predict next state only

    def forward(self, z, s_t, u_t):
        h = F.relu(self.ln1(self.fc1(torch.cat([z, s_t, u_t], dim=1))))
        h = F.relu(self.ln2(self.fc2(h)))
        return self.fc_out(h)


